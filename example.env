# Copy this file to `.env` for your own local reference.
# The app reads these values from the process environment at runtime.
# It does not auto-load `.env`, so export the variables in your shell,
# dev launcher, container config, or hosting environment.

PLCREX_MAX_UPLOAD_BYTES=16777216
PLCREX_MAX_TEXT_INPUT_CHARS=16384
PLCREX_MAX_OPTIONS_BYTES=16384
PLCREX_PROCESS_TIMEOUT_SECONDS=120
PLCREX_MAX_OUTPUT_FILES=24
PLCREX_MAX_OUTPUT_FILE_BYTES=2097152
PLCREX_MAX_TOTAL_OUTPUT_BYTES=8388608
PLCREX_MAX_LOG_BYTES=262144
